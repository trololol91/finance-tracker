# Docker Compose Environment Variables
# Copy this file to .env and update with your actual values
# NEVER commit the .env file to version control!

# =============================================================================
# REQUIRED — the app will not start without these
# =============================================================================

# PostgreSQL credentials
# Generate: openssl rand -base64 32
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=finance_tracker

# JWT signing secret — must be 32+ characters
# Generate: openssl rand -base64 32
JWT_SECRET=
# Duration format for both vars below: an integer + one unit (s/m/h/d only,
# e.g. 30s, 15m, 12h, 30d) — no other formats (weeks, years, decimals) are accepted.
# Access token lifetime — kept short since it's stored in the browser and sent on every request
JWT_EXPIRES_IN=15m
# Refresh token lifetime when "remember me" is checked at login (sliding — renewed on each use)
JWT_REFRESH_EXPIRES_IN=30d

# AES-256-GCM key for encrypting stored bank credentials
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CREDENTIALS_ENCRYPTION_KEY=

# URL your browser uses to reach the frontend (used for CORS)
# Home server subdomain:  https://finance.yourserver.com
# Local Docker:           http://localhost:3002
CORS_ORIGIN=http://localhost:3002

# URL your browser uses to reach the backend API
# Home server subdomain:  https://finance-api.yourserver.com
# Local only:             http://localhost:3001
VITE_API_BASE_URL=http://localhost:3001

# =============================================================================
# OPTIONAL — sensible defaults are provided
# =============================================================================

# OAuth 2.1 authorization server (lets Claude's "Add custom connector" dialog
# connect to packages/mcp-server via browser-redirect login instead of a
# manually-pasted API token). See test-plan/oauth-connector/implementation-plan.md.
#
# Absolute URL the backend is reachable at from the internet (used to build
# the RFC 8414 metadata document's endpoint URLs) — same value as
# VITE_API_BASE_URL above unless the backend has a different public hostname.
# Also read by packages/mcp-server (as its OAuth issuer identifier) — keep
# this in sync if you override it, since it must be HTTPS or localhost or
# mcp-server refuses to start.
PUBLIC_API_BASE_URL=http://localhost:3001
# Phase 1 ships one hardcoded client (no dynamic registration yet). Any
# non-empty client_id works locally; set to Claude's actual client_id once
# known.
OAUTH_STATIC_CLIENT_ID=claude-ai
# Comma-separated redirect URIs Claude is allowed to send the auth code to —
# confirm the real value empirically by attempting the connector once.
OAUTH_STATIC_REDIRECT_URIS=https://claude.ai/api/mcp/auth_callback
# mcp-server's own externally-reachable URL — used as the OAuth "resource"
# identifier in its protected-resource metadata document. Distinct from
# FINANCE_TRACKER_URL below (that's mcp-server -> backend, not client -> mcp-server).
MCP_PUBLIC_URL=http://localhost:3010

# Application
NODE_ENV=production
PORT=3001

# Scraper plugins
# Path inside the container where scraper plugin zips are installed
SCRAPER_PLUGIN_DIR=/data/scraper-plugins

# Playwright remote server URL — leave unset for local development (browser launches locally).
# When running via docker-compose this is set automatically to ws://playwright-server:3003.
# Override only if you run the playwright-server container on a different host/port.
# PLAYWRIGHT_SERVER_URL=ws://playwright-server:3003/ws

# =============================================================================
# OPTIONAL — only needed if you use these features
# =============================================================================

# Web push notifications — generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# SMTP for MFA fallback email notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Playwright session storage (cookies for banks that don't require MFA every run)
SCRAPER_SESSION_DIR=.scraper-session

# =============================================================================
# AI CATEGORIZATION — optional, enables LLM-based transaction categorization
# =============================================================================

# Provider to use: anthropic (default) or openai
AI_PROVIDER=anthropic

# Model name — defaults to claude-haiku-4-5-20251001 (anthropic) or gpt-4o-mini (openai)
AI_MODEL=claude-haiku-4-5-20251001

# API key for the selected provider — leave blank to disable AI categorization
ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
