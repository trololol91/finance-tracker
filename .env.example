# Docker Compose Environment Variables
# Copy this file to .env and update with your actual values

# Application
SECRET_KEY=your_secret_key_here_minimum_32_characters_long
NODE_ENV=production
LOG_LEVEL=info

# PostgreSQL Database
POSTGRES_USER=finance_user
POSTGRES_PASSWORD=change_this_password
POSTGRES_DB=finance_tracker

# Backend Configuration
PORT=3000
DATABASE_SYNC=false
DATABASE_LOGGING=false
DATABASE_URL=postgresql://finance_user:change_this_password@localhost:5432/finance_tracker

# JWT Authentication
JWT_SECRET=your_jwt_secret_key_here_minimum_32_characters_long_for_production
JWT_EXPIRES_IN=7d

# Frontend Configuration
VITE_API_URL=http://localhost:3001
