# Docker Compose Environment Variables
# Copy this file to .env and update with your actual values
# NEVER commit the .env file to version control!

# =============================================================================
# SECURITY WARNING: Generate strong random values for passwords and secrets!
# =============================================================================
# Generate secure passwords using one of these methods:
#   - openssl rand -base64 32
#   - node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
#   - Use a password manager to generate 32+ character passwords

# PostgreSQL Database (REQUIRED - no defaults)
# Generate strong random values for production
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=finance_tracker

# JWT Authentication (REQUIRED - no defaults)
# Must be at least 32 characters long for security
JWT_SECRET=
JWT_EXPIRES_IN=7d

# Application Configuration
NODE_ENV=production
PORT=3001

# Frontend Configuration
VITE_API_URL=http://localhost:3001

# =============================================================================
# Scraper Module (Phase 7 — Transaction Import & Automated Sync)
# =============================================================================
# AES-256-GCM key for encrypting bank credentials at rest.
# REQUIRED once ScraperModule is loaded. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CREDENTIALS_ENCRYPTION_KEY=

# Docker volume path where external bank scraper plugins (npm packages) are mounted.
SCRAPER_PLUGIN_DIR=/app/plugins

# Directory for Playwright storageState files (session cookies for banks that
# don't require MFA on every run). Add to .gitignore.
SCRAPER_SESSION_DIR=.scraper-session

# Set to false locally to watch the browser while developing/debugging scrapers.
PLAYWRIGHT_HEADLESS=true

# Web Push VAPID keys — generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# SMTP / email settings for MFA fallback notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
