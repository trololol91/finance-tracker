# Docker Compose Environment Variables
# Copy this file to .env and update with your actual values
# NEVER commit the .env file to version control!

# =============================================================================
# REQUIRED — the app will not start without these
# =============================================================================

# PostgreSQL credentials
# Generate: openssl rand -base64 32
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=finance_tracker

# JWT signing secret — must be 32+ characters
# Generate: openssl rand -base64 32
JWT_SECRET=
JWT_EXPIRES_IN=7d

# AES-256-GCM key for encrypting stored bank credentials
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CREDENTIALS_ENCRYPTION_KEY=

# URL your browser uses to reach the frontend (used for CORS)
# Home server subdomain:  https://finance.yourserver.com
# Local Docker:           http://localhost:3002
CORS_ORIGIN=http://localhost:3002

# URL your browser uses to reach the backend API
# Home server subdomain:  https://finance-api.yourserver.com
# Local only:             http://localhost:3001
VITE_API_BASE_URL=http://localhost:3001

# =============================================================================
# OPTIONAL — sensible defaults are provided
# =============================================================================

# Application
NODE_ENV=production
PORT=3001

# Scraper plugins
# Path inside the container where scraper plugin zips are installed
SCRAPER_PLUGIN_DIR=/data/scraper-plugins

# Playwright remote server URL — leave unset for local development (browser launches locally).
# When running via docker-compose this is set automatically to ws://playwright-server:3003.
# Override only if you run the playwright-server container on a different host/port.
# PLAYWRIGHT_SERVER_URL=ws://playwright-server:3003/ws

# =============================================================================
# OPTIONAL — only needed if you use these features
# =============================================================================

# Web push notifications — generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@example.com

# SMTP for MFA fallback email notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Playwright session storage (cookies for banks that don't require MFA every run)
SCRAPER_SESSION_DIR=.scraper-session
