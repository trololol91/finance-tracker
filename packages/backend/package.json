    "web-push": "3.6.7"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.2.0",
    "@eslint/js": "9.18.0",
    "@nestjs/cli": "11.0.0",
    "@nestjs/schematics": "11.0.0",
    "@nestjs/testing": "11.0.1",
    "@stylistic/eslint-plugin": "4.2.0",
    "@swc/cli": "0.6.0",
    "@swc/core": "1.10.7",
    "@types/adm-zip": "0.5.7",
    "@types/bcrypt": "6.0.0",
    "@types/express": "5.0.0",
    "@types/multer": "2.0.0",
