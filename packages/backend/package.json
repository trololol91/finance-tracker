    "@nestjs/swagger": "11.2.6",
    "@prisma/adapter-pg": "7.4.0",
    "@prisma/client": "7.4.0",
    "@types/papaparse": "5.5.2",
    "adm-zip": "0.5.16",
    "bcrypt": "6.0.0",
    "cron-validator": "1.4.0",
    "dotenv": "16.6.1",
    "googleapis": "168.0.0",
    "joi": "18.0.2",
    "nodemailer": "8.0.1",
    "openai": "6.32.0",
    "papaparse": "5.5.3",
    "passport": "0.7.0",
