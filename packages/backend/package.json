  "private": true,
  "license": "UNLICENSED",
  "type": "module",
  "imports": {
    "#root/*": "./dist/*",
    "#common/*": "./dist/common/*",
    "#config/*": "./dist/config/*",
    "#database/*": "./dist/database/*",
    "#auth/*": "./dist/auth/*",
    "#users/*": "./dist/users/*",
    "#transactions/*": "./dist/transactions/*",
    "#categories/*": "./dist/categories/*",
    "#accounts/*": "./dist/accounts/*",
    "#budgets/*": "./dist/budgets/*",
    "#reports/*": "./dist/reports/*",
    "#scraper/*": "./dist/scraper/*",
    "#ai/*": "./dist/ai/*",
    "#integrations/*": "./dist/integrations/*",
    "#push/*": "./dist/push/*",
    "#generated/*": "./dist/generated/*",
    "#dashboard/*": "./dist/dashboard/*",
    "#ai-categorization/*": "./dist/ai-categorization/*",
    "#category-rules/*": "./dist/category-rules/*",
    "#api-tokens/*": "./dist/api-tokens/*"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "engines": {
    "node": "24.13.0"
  },
  "scripts": {
    "build": "nest build",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "dev": "nest start --watch",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main.js",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "lint:eslint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:coverage": "vitest run --coverage",
    "test:debug": "vitest --inspect-brk --inspect --no-file-parallelism",
    "test:e2e": "vitest run --config ./test/vitest-e2e.config.ts",
    "test:ui": "vitest --ui",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "seed": "tsx prisma/seed.ts"
  },
