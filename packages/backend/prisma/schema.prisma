// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

enum TransactionType {
  income
  expense
  transfer
}

enum TransferDirection {
  in
  out
}

enum AccountType {
  checking
  savings
  credit
  investment
  loan
  other
}

enum ImportStatus {
  pending
  processing
  completed
  failed
}

enum SyncRunStatus {
  success
  failed
  mfa_required
}

enum FileType {
  csv
}

model User {
  id             String    @id @default(uuid()) @db.Uuid
  email          String    @unique
  passwordHash   String    @map("password_hash")
  firstName      String?   @map("first_name")
  lastName       String?   @map("last_name")
  
  // Security & Account Management
  emailVerified  Boolean   @default(false) @map("email_verified")
  isActive       Boolean   @default(true) @map("is_active")
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz
  
  // User Preferences
  timezone       String    @default("UTC")
  currency       String    @default("USD")
  
  // Role
  role           UserRole  @default(USER)
  
  // Timestamps
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  transactions   Transaction[]
  categories     Category[]
  accounts       Account[]
  importJobs     ImportJob[]
  syncSchedules  SyncSchedule[]
  syncJobs       SyncJob[]
  categoryRules  CategoryRule[]
  apiTokens      ApiToken[]

  // Notification preferences for scraper MFA alerts
  notifyEmail    Boolean  @default(true)  @map("notify_email")

  @@map("users")
}

model Transaction {
  id              String          @id @default(uuid()) @db.Uuid
  userId          String          @map("user_id") @db.Uuid

  // Financial fields
  amount          Decimal         @db.Decimal(10, 2)
  description     String
  notes           String?

  // Optional categorisation (foreign keys added when modules are built)
  categoryId      String?         @map("category_id") @db.Uuid
  accountId       String?         @map("account_id") @db.Uuid

  // Classification
  transactionType   TransactionType    @map("transaction_type")
  transferDirection TransferDirection? @map("transfer_direction")

  // Dates
  date            DateTime        @db.Timestamptz
  originalDate    DateTime        @map("original_date") @db.Timestamptz

  // State
  isActive        Boolean         @default(true) @map("is_active")
  isPending       Boolean         @default(false) @map("is_pending")

  // OFX / scraper dedup key (bank-assigned FITID or sha256 syntheticId)
  // Partial unique index (userId, fitid) WHERE fitid IS NOT NULL enforced via raw migration.
  fitid           String?

  // Timestamps
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime        @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  user            User            @relation(fields: [userId], references: [id])
  category        Category?       @relation(fields: [categoryId], references: [id])
  account         Account?        @relation(fields: [accountId], references: [id])

  @@index([userId])
  @@index([userId, date])
  @@index([userId, isActive])
  @@map("transactions")
}

model Category {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @map("user_id") @db.Uuid

  name        String
  description String?
  color       String?
  icon        String?

  parentId    String?   @map("parent_id") @db.Uuid

  isActive    Boolean   @default(true) @map("is_active")

  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @updatedAt      @map("updated_at") @db.Timestamptz

  // Relations
  user         User          @relation(fields: [userId], references: [id])
  parent       Category?     @relation("CategoryChildren", fields: [parentId], references: [id])
  children     Category[]    @relation("CategoryChildren")
  transactions Transaction[]
  rules        CategoryRule[]

  @@unique([userId, name, parentId])
  @@index([userId])
  @@index([userId, isActive])
  @@map("categories")
}

model Account {
  id             String      @id @default(uuid()) @db.Uuid
  userId         String      @map("user_id") @db.Uuid

  name           String
  type           AccountType @default(other)
  institution    String?
  currency       String      @default("CAD")
  openingBalance Decimal     @default(0) @map("opening_balance") @db.Decimal(12, 2)
  color          String?
  notes          String?

  isActive       Boolean     @default(true) @map("is_active")

  createdAt      DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime    @updatedAt      @map("updated_at") @db.Timestamptz

  // Relations
  user           User        @relation(fields: [userId], references: [id])
  transactions   Transaction[]
  importJobs     ImportJob[]
  syncSchedules  SyncSchedule[]

  @@unique([userId, name])
  @@index([userId])
  @@index([userId, isActive])
  @@map("accounts")
}

model ImportJob {
  id             String       @id @default(uuid()) @db.Uuid
  userId         String       @map("user_id") @db.Uuid
  accountId      String?      @map("account_id") @db.Uuid
  source         String       @default("file")

  filename       String
  fileType       FileType     @map("file_type")
  status         ImportStatus @default(pending)

  rowCount       Int          @default(0) @map("row_count")
  importedCount  Int          @default(0) @map("imported_count")
  skippedCount   Int          @default(0) @map("skipped_count")
  errorMessage   String?      @map("error_message")

  createdAt      DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime     @updatedAt      @map("updated_at") @db.Timestamptz

  user           User         @relation(fields: [userId], references: [id])
  account        Account?     @relation(fields: [accountId], references: [id])

  @@index([userId])
  @@index([userId, status])
  @@map("import_jobs")
}

model CategoryRule {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  pattern    String
  categoryId String   @map("category_id") @db.Uuid

  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime @updatedAt      @map("updated_at") @db.Timestamptz

  user       User     @relation(fields: [userId], references: [id])
  category   Category @relation(fields: [categoryId], references: [id])

  @@unique([userId, pattern])
  @@index([userId])
  @@map("category_rules")
}

model SyncSchedule {
  id              String         @id @default(uuid()) @db.Uuid
  userId          String         @map("user_id") @db.Uuid
  accountId       String         @map("account_id") @db.Uuid

  bankId          String         @map("bank_id")
  pluginConfigEnc  String         @map("plugin_config_enc")
  cron            String         @default("0 8 * * *")
  enabled         Boolean        @default(true)

  lastRunAt            DateTime?      @map("last_run_at")              @db.Timestamptz
  lastRunStatus        SyncRunStatus? @map("last_run_status")
  lastSuccessfulSyncAt DateTime?      @map("last_successful_sync_at")  @db.Timestamptz
  lookbackDays         Int            @default(3)                      @map("lookback_days")
  autoCategorizeLlm    Boolean        @default(false)                  @map("auto_categorize_llm")

  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime       @updatedAt      @map("updated_at") @db.Timestamptz

  user            User           @relation(fields: [userId], references: [id])
  account         Account        @relation(fields: [accountId], references: [id])
  syncJobs        SyncJob[]

  @@unique([userId, accountId])
  @@index([userId])
  @@index([userId, enabled])
  @@map("sync_schedules")
}

model SyncJob {
  id               String        @id @default(uuid()) @db.Uuid
  userId           String        @map("user_id") @db.Uuid
  syncScheduleId   String        @map("sync_schedule_id") @db.Uuid

  triggeredBy      String        @default("cron")     @map("triggered_by")
  requestStartDate DateTime?     @map("request_start_date") @db.Timestamptz
  requestEndDate   DateTime?     @map("request_end_date")   @db.Timestamptz

  status           String        @default("pending")
  message          String?
  mfaChallenge     String?       @map("mfa_challenge")
  importedCount    Int           @default(0) @map("imported_count")
  skippedCount     Int           @default(0) @map("skipped_count")
  errorMessage     String?       @map("error_message")

  startedAt        DateTime?     @map("started_at")   @db.Timestamptz
  completedAt      DateTime?     @map("completed_at") @db.Timestamptz

  createdAt        DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime      @updatedAt      @map("updated_at") @db.Timestamptz

  user             User          @relation(fields: [userId], references: [id])
  syncSchedule     SyncSchedule  @relation(fields: [syncScheduleId], references: [id])

  @@index([userId])
  @@index([syncScheduleId])
  @@index([userId, status])
  @@map("sync_jobs")
}

model ApiToken {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  name       String
  tokenHash  String    @unique @map("token_hash")
  scopes     String[]
  lastUsedAt DateTime? @map("last_used_at") @db.Timestamptz
  expiresAt  DateTime? @map("expires_at") @db.Timestamptz
  deletedAt  DateTime? @map("deleted_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  @@index([userId])
  // Partial index covering the auth lookup: tokenHash WHERE deletedAt IS NULL.
  // Prisma doesn't support partial index syntax directly; add via a custom migration if needed.
  @@map("api_tokens")
}
