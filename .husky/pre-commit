#!/bin/sh
set -e
STAGED=$(git diff --cached --name-only)

backend_changed=false
frontend_changed=false
mcp_changed=false

echo "$STAGED" | grep -q "^packages/backend/"    && backend_changed=true
echo "$STAGED" | grep -q "^packages/frontend/"   && frontend_changed=true
echo "$STAGED" | grep -q "^packages/mcp-server/" && mcp_changed=true

if $backend_changed; then
  echo "[pre-commit] backend changes detected — running typecheck, lint, coverage"
  npm run -w packages/backend typecheck
  npm run -w packages/backend lint:eslint
  npm run -w packages/backend test:coverage
fi

if $frontend_changed; then
  echo "[pre-commit] frontend changes detected — running typecheck, lint, coverage"
  npm run -w packages/frontend typecheck
  npm run -w packages/frontend lint:eslint
  npm run -w packages/frontend test:coverage
fi

if $mcp_changed; then
  echo "[pre-commit] mcp-server changes detected — running typecheck, lint, coverage"
  npm run -w packages/mcp-server typecheck
  npm run -w packages/mcp-server lint:eslint
  npm run -w packages/mcp-server test:coverage
fi

if ! $backend_changed && ! $frontend_changed && ! $mcp_changed; then
  echo "[pre-commit] no package source changes — skipping checks"
fi
