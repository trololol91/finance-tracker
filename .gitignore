# dependencies
node_modules/
.pnp
.pnp.js

# Testing
coverage/

# Production
build/
dist/
out/
*.tsbuildinfo

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Environment files
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# Editor directories and files
.vscode/*
!.vscode/extensions.json
!.vscode/mcp.json
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Backend specific
packages/backend/resource/**
packages/backend/dist
packages/backend/logs

# Frontend specific
packages/frontend/dist
packages/frontend/.vite/

# Ignore database files
*.db

# Scripts
exports/*
accountactivity.csv

# Playwright MCP state and cache
.playwright-mcp/

